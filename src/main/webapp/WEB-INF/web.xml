<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>TA Recruitment System</display-name>
    <listener>
        <listener-class>com.bupt.ta.web.AppListener</listener-class>
    </listener>
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TAAuthServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.TAAuthServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TADashboardServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.TADashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MOAuthServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.MOAuthServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MODashboardServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.MODashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.bupt.ta.web.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TAAuthServlet</servlet-name>
        <url-pattern>/ta/auth</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TADashboardServlet</servlet-name>
        <url-pattern>/ta/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MOAuthServlet</servlet-name>
        <url-pattern>/mo/auth</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MODashboardServlet</servlet-name>
        <url-pattern>/mo/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
